{
  "name": "TypeRace",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".",
    "args": {
      "Node_VERSION": "20-alpine"
    }
  },
  "workspaceFolder": "/workspace",
  "forwardPorts": [3000],
  "customizations": {
    "vscode": {
        "extensions": [
            "dbaeumer.vscode-eslint",
            "esbenp.prettier-vscode",
            "formulahendry.auto-close-tag",
            "formulahendry.auto-rename-tag"
        ]
    }
  },
  "postCreateCommand": "npm install",
  "remoteUser": "node"
}